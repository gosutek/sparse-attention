{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "native"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MEM_DEBUG": "OFF",
        "CMAKE_CUDA_FLAGS_DEBUG": "-g -G -O0",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -O0"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CUDA_FLAGS_RELEASE": "-O2 -lineinfo",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -march=native"
      }
    }
  ]
}
